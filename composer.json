{
  "name": "wazobia/nexus-mcp-laravel",
  "description": "Laravel HMAC middleware and MCP server helpers for the Nexus MCP ecosystem",
  "type": "library",
  "license": "MIT",
  "keywords": ["laravel", "mcp", "hmac", "nexus", "wazobia"],
  "require": {
    "php": "^8.1",
    "guzzlehttp/guzzle": "^7.0",
    "illuminate/http": "^10.0|^11.0",
    "illuminate/routing": "^10.0|^11.0",
    "illuminate/support": "^10.0|^11.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0",
    "orchestra/testbench": "^8.0|^9.0"
  },
  "autoload": {
    "psr-4": {
      "Wazobia\\NexusMcp\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Wazobia\\NexusMcp\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Wazobia\\NexusMcp\\McpServiceProvider"
      ]
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
